    "pinia": "^2.3.1",
    "tailwind-merge": "^3.3.0",
    "tesseract.js": "^7.0.0",
    "vue": "^3.4.15",
    "vue-chartjs": "^5.3.0",
    "vue-router": "^4.2.5"
  },
  "devDependencies": {
    "@types/node": "^22.15.30",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
